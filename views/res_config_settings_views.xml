<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_whatsapp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.whatsapp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="WhatsApp Receipt" name="pos_whatsapp_receipt" logo="/pos_whatsapp_receipt/static/description/icon.png">
                    <block title="OpenWA WhatsApp API" name="openwa_config">
                        <setting string="Base URL" help="URL server OpenWA, contoh: http://localhost:2785">
                            <field name="openwa_base_url" placeholder="http://localhost:2785"/>
                        </setting>
                        <setting string="API Key" help="API key dari OpenWA (buat di menu Auth > API Keys)">
                            <field name="openwa_api_key" password="True"/>
                        </setting>
                        <setting string="Session ID" help="ID sesi WhatsApp di OpenWA (contoh: default)">
                            <field name="openwa_session_id" placeholder="default"/>
                        </setting>
                        <setting string="Template Pesan" help="Variabel: {total} {date} {receipt_url}">
                            <field name="openwa_message_template" widget="text"/>
                        </setting>
                    </block>
                    <block title="YOURLS URL Shortener" name="yourls_config">
                        <setting string="YOURLS URL" help="URL server YOURLS, contoh: https://s.domain.com">
                            <field name="yourls_url" placeholder="https://s.domain.com"/>
                        </setting>
                        <setting string="Signature Token" help="Signature token dari YOURLS (Tools > Secure passwordless API call)">
                            <field name="yourls_signature" password="True"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
