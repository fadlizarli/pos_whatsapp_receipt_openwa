<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_whatsapp" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.whatsapp</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="WhatsApp Receipt" name="pos_whatsapp_receipt" logo="/pos_whatsapp_receipt/static/description/icon.png">
                    <block title="Fonnte WhatsApp API" name="fonnte_config">
                        <setting string="API Token" help="Token dari akun Fonnte (md.fonnte.com)">
                            <field name="fonnte_token" password="True"/>
                        </setting>
                        <setting string="Nomor Pengirim" help="Nomor WhatsApp terhubung ke Fonnte (628xxx)">
                            <field name="fonnte_sender" placeholder="628xxxxxxxxxx"/>
                        </setting>
                        <setting string="Template Pesan" help="Variabel: {total} {date} {receipt_url}">
                            <field name="fonnte_message_template" widget="text"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
